# Forces LF everywhere in repo

# Normalize all text files to LF
* text=auto eol=lf

# Explicitly ensure shell scripts are LF (important for containers)
*.sh text eol=lf

*.py text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Binary files (prevent corruption)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.npy binary
*.pt binary
*.pth binary
*.h5 binary